{
  "Jwt": {
    "Key": "super_secret_key_12345_super_secret_key_67890",
    "Issuer": "ihbplatform",
    "Audience": "ihbplatform_frontend"
  },
  "ReverseProxy": {
    "Routes": {
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": { "Path": "/user/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/user" }]
      }
    },
    "Clusters": {
      "user-cluster": {
        "Destinations": {
          "user_api": { "Address": "http://localhost:5000" }
        }
      }
    }
  }
}